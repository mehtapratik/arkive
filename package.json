{
  "name": "arkive",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "ingest": "node scripts/ingest-docs.mjs",
    "icons:raster": "node scripts/generate-raster-icons.mjs",
    "search:index": "node scripts/build-search-index.mjs",
    "predev": "npm run icons:raster && npm run ingest && npm run search:index",
    "dev": "astro dev",
    "prebuild": "npm run icons:raster && npm run ingest && npm run search:index",
    "build": "astro build && npx pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "5.0.6",
    "@astrojs/rss": "4.0.18",
    "@fontsource-variable/jetbrains-mono": "5.2.8",
    "@fontsource/averia-serif-libre": "5.2.7",
    "@fontsource/barlow": "5.2.8",
    "astro": "^6.3.4",
    "js-yaml": "4.1.1",
    "pagefind": "1.5.2",
    "rehype-slug": "6.0.0",
    "unist-util-visit": "5.1.0"
  },
  "devDependencies": {
    "sharp": "0.34.5"
  }
}
